# export NGOK_TOKEN=op://Jarvis/Ngrok/NGOK_TOKEN

export NGROK_AUTH_TOKEN=op://Jarvis/Ngrok/NGROK_AUTH_TOKEN

# Cloudflare
# export CLOUDFLARE_ACCOUNT_ID=op://Jarvis/Cyrus/CLOUDFLARE_ACCOUNT_ID
# export CLOUDFLARE_SUBDOMAIN=op://Jarvis/Cyrus/CLOUDFLARE_SUBDOMAIN
# export CLOUDFLARE_API_TOKEN=op://Jarvis/Cyrus/CLOUDFLARE_API_TOKEN


# =============================================================================
# SETUP CONFIGURATION - Choose one option below
# =============================================================================
# Handles: OAuth callbacks + Linear webhooks

# Option 1: Local development with ngrok
# Run: ngrok http 3456
# Then use the ngrok URL as CYRUS_BASE_URL
# export CYRUS_BASE_URL=https://prebrute-alonso-rigorously.ngrok-free.app
# export CYRUS_SERVER_PORT=3456

# Option 2: Self-hosted Cyrus on remote server with public domain/IP
# export CYRUS_BASE_URL=https://cyrus-proxy.gudzenkov.workers.dev
# export CYRUS_SERVER_PORT=3456                        # Server port
# export CYRUS_HOST_EXTERNAL=true                      # Listen on 0.0.0.0 for external connections

# Option 3: Self-managed setup using Cyrus proxy
# export LINEAR_DIRECT_WEBHOOKS=true
export PROXY_URL=https://cyrus-proxy.gudzenkov.workers.dev
# export CYRUS_BASE_URL=https://cyrus-proxy.gudzenkov.workers.dev
# export CYRUS_HOST_EXTERNAL=true
# export CYRUS_WEBHOOK_DEBUG="true"

# Direct Linear OAuth configuration (optional - for self-hosted Linear OAuth)
# export LINEAR_DIRECT_WEBHOOKS=true  # Enable direct webhook handling without Cyrus proxy
# LINEAR_CLIENT_ID=op://Jarvis/Linear/LINEAR_CLIENT_ID
# LINEAR_CLIENT_SECRET=op://Jarvis/Linear/LINEAR_CLIENT_SECRET
# LINEAR_WEBHOOK_SECRET=op://Jarvis/Linear/LINEAR_WEBHOOK_SECRET

# Claude Code models
export CYRUS_DEFAULT_MODEL=sonnet
export CYRUS_DEFAULT_FALLBACK_MODEL=haiku
